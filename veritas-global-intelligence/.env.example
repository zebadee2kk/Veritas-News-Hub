# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps.
GOOGLE_MAPS_PLATFORM_KEY="MY_GOOGLE_MAPS_KEY"

# NEWS_API_KEY: Required for fetching news (e.g. from newsapi.org).
NEWS_API_KEY="MY_NEWS_API_KEY"

# X/TWITTER_API_KEYS: Optional for social intelligence.
TWITTER_API_KEY="MY_TWITTER_KEY"
TWITTER_BEARER_TOKEN="MY_TWITTER_BEARER_TOKEN"

# GROK_API_KEY: Optional for secondary intelligence comparison (xAI).
GROK_API_KEY="MY_GROK_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
